{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping each InnerWarden agent's /metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "InnerWarden — AI Agent Fleet",
  "description": "Fleet-wide visibility across every host running an InnerWarden agent: per-tenant AI-agent activity and host-level detection in one place. Each scrape target is one node; the `instance` label is the host and `tenant` is the attributed agent/employee/pod.",
  "tags": ["innerwarden", "ai-agents", "fleet", "security"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-6h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "node",
        "label": "Node",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(up{job=~\"innerwarden.*\"}, instance)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      },
      {
        "name": "tenant",
        "label": "Tenant / agent",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(innerwarden_incidents_by_tenant, tenant)",
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "current": { "text": "All", "value": "$__all" },
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Fleet overview",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "stat",
      "title": "Nodes reporting",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } },
      "targets": [{ "expr": "count(up{job=~\"innerwarden.*\"} == 1)", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Incidents today",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1 }, { "color": "red", "value": 50 }] } } },
      "targets": [{ "expr": "sum(innerwarden_incidents_total{instance=~\"$node\"})", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Decisions today",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(innerwarden_decisions_total{instance=~\"$node\"})", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Live skill executions",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(innerwarden_executions_total{mode=\"live\",instance=~\"$node\"})", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "AI latency (avg ms)",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "ms" } },
      "targets": [{ "expr": "avg(innerwarden_ai_latency_avg_ms{instance=~\"$node\"})", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "ATR rules loaded (min)",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "green", "value": 1 }] } } },
      "description": "0 on any node = agent-guard degraded (rules failed to load).",
      "targets": [{ "expr": "min(innerwarden_agent_guard_atr_rules_loaded{instance=~\"$node\"})", "refId": "A" }]
    },
    {
      "type": "row",
      "title": "Per-tenant AI-agent activity (each Claude Code = a tenant)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "type": "timeseries",
      "title": "Incidents by tenant",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Security incidents attributed to each agent/employee/pod (spec 084 kernel cgroup attribution — the agent can't spoof it).",
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } } } },
      "targets": [{ "expr": "sum by (tenant) (innerwarden_incidents_by_tenant{tenant=~\"$tenant\"})", "legendFormat": "{{tenant}}", "refId": "A" }]
    },
    {
      "type": "table",
      "title": "Top tenants by incidents",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Value", "desc": true }] },
      "targets": [{ "expr": "sort_desc(sum by (tenant) (innerwarden_incidents_by_tenant{tenant=~\"$tenant\"}))", "format": "table", "instant": true, "refId": "A" }],
      "transformations": [{ "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "tenant": "Tenant / agent", "Value": "Incidents" } } }]
    },
    {
      "type": "timeseries",
      "title": "Command checks by verdict (fleet)",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Every command each AI agent tried, judged allow / review / deny by the agent-guard. The 'what did the agents try, and what got blocked' view.",
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } }, "overrides": [ { "matcher": { "id": "byName", "options": "deny" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } } ] }, { "matcher": { "id": "byName", "options": "review" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "yellow" } } ] }, { "matcher": { "id": "byName", "options": "allow" }, "properties": [ { "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } } ] } ] },
      "targets": [{ "expr": "sum by (verdict) (innerwarden_agent_guard_checks_total{tenant=~\"$tenant\"})", "legendFormat": "{{verdict}}", "refId": "A" }]
    },
    {
      "type": "table",
      "title": "Denied commands by tenant",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Which agent/employee/pod hit the most denied commands — the ones to look at first.",
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Denied", "desc": true }] },
      "targets": [{ "expr": "sort_desc(sum by (tenant) (innerwarden_agent_guard_checks_total{verdict=\"deny\",tenant=~\"$tenant\"}))", "format": "table", "instant": true, "refId": "A" }],
      "transformations": [{ "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "tenant": "Tenant / agent", "Value": "Denied" } } }]
    },
    {
      "type": "row",
      "title": "Decisions & response",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "type": "timeseries",
      "title": "Decisions by action",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "What the agent decided to do (block / monitor / ignore / etc) across the fleet.",
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60, "stacking": { "mode": "normal" } } } },
      "targets": [{ "expr": "sum by (action) (innerwarden_decisions_total{instance=~\"$node\"})", "legendFormat": "{{action}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Skill executions (live vs dry-run)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 } } },
      "targets": [{ "expr": "sum by (mode) (innerwarden_executions_total{instance=~\"$node\"})", "legendFormat": "{{mode}}", "refId": "A" }]
    },
    {
      "type": "row",
      "title": "Host-level detection (the EDR underneath)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }
    },
    {
      "type": "timeseries",
      "title": "Incidents by detector",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15 } } },
      "targets": [{ "expr": "topk(10, sum by (detector) (innerwarden_incidents_total{instance=~\"$node\"}))", "legendFormat": "{{detector}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Events by collector",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 } } },
      "targets": [{ "expr": "topk(10, sum by (collector) (innerwarden_events_total{instance=~\"$node\"}))", "legendFormat": "{{collector}}", "refId": "A" }]
    },
    {
      "type": "row",
      "title": "Fleet health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 }
    },
    {
      "type": "timeseries",
      "title": "Agent up per node",
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "min": 0, "max": 1, "custom": { "drawStyle": "line", "fillOpacity": 30 } } },
      "targets": [{ "expr": "up{job=~\"innerwarden.*\",instance=~\"$node\"}", "legendFormat": "{{instance}}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Errors by component",
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "bars", "fillOpacity": 60 } } },
      "targets": [{ "expr": "sum by (component) (innerwarden_errors_total{instance=~\"$node\"})", "legendFormat": "{{component}}", "refId": "A" }]
    },
    {
      "type": "stat",
      "title": "Active responses (fleet)",
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 33 },
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [{ "expr": "sum(innerwarden_responses_active{instance=~\"$node\"})", "refId": "A" }]
    }
  ]
}
